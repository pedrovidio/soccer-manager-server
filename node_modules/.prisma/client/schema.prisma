// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum TransactionType {
  MONTHLY
  SPOT
  GOALKEEPER_SERVICE
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELLED
}

enum FootballLevel {
  PROFESSIONAL
  AMATEUR
  CASUAL
}

model Athlete {
  id                     String        @id @default(uuid()) @map("id")
  name                   String        @map("name")
  cpf                    String        @unique @map("cpf")
  email                  String        @unique @map("email")
  phone                  String        @map("phone")
  addressCep             String        @map("address_cep")
  addressStreet          String        @map("address_street")
  addressNumber          String        @map("address_number")
  addressComplement      String?       @map("address_complement")
  addressNeighborhood    String        @map("address_neighborhood")
  addressCity            String        @map("address_city")
  addressState           String        @map("address_state")
  age                    Int           @map("age")
  gender                 String        @map("gender")
  position               String        @map("position")
  footballLevel          FootballLevel @map("football_level")
  statsPace              Int           @map("stats_pace")
  statsShooting          Int           @map("stats_shooting")
  statsPassing           Int           @map("stats_passing")
  statsDribbling         Int           @map("stats_dribbling")
  statsDefense           Int           @map("stats_defense")
  statsPhysical          Int           @map("stats_physical")
  latitude               Float?        @map("latitude")
  longitude              Float?        @map("longitude")
  isGoalkeeperForHire    Boolean       @default(false) @map("is_goalkeeper_for_hire")
  isInjured              Boolean       @default(false) @map("is_injured")
  financialDebt          Float         @default(0) @map("financial_debt")
  hasCompletedAssessment Boolean       @default(false) @map("has_completed_assessment")
  pixKey                 String?       @map("pix_key")

  // Relations
  availabilities        Availability[]
  financialTransactions FinancialTransaction[]
  assessment            Assessment?

  @@map("athletes")
}

enum YearsPlaying {
  LESS_THAN_2
  TWO_TO_5
  SIX_TO_10
  MORE_THAN_10
}

enum WeeklyFrequency {
  RARELY
  ONE_TO_2
  THREE_OR_MORE
}

model Assessment {
  id                   String          @id @default(uuid()) @map("id")
  athleteId            String          @unique @map("athlete_id")
  playedProfessionally Boolean         @map("played_professionally")
  highestLevel         FootballLevel   @map("highest_level")
  yearsPlaying         YearsPlaying    @map("years_playing")
  weeklyFrequency      WeeklyFrequency @map("weekly_frequency")
  selfRatedPace        Int             @map("self_rated_pace")
  selfRatedShooting    Int             @map("self_rated_shooting")
  selfRatedPassing     Int             @map("self_rated_passing")
  selfRatedDribbling   Int             @map("self_rated_dribbling")
  selfRatedDefense     Int             @map("self_rated_defense")
  selfRatedPhysical    Int             @map("self_rated_physical")
  preferredPosition    String          @map("preferred_position")
  submittedAt          DateTime        @default(now()) @map("submitted_at")

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model Availability {
  id        String @id @default(uuid()) @map("id")
  athleteId String @map("athlete_id")
  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time")
  endTime   String @map("end_time")

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

model Group {
  id                    String   @id @default(uuid()) @map("id")
  name                  String   @map("name")
  description           String   @map("description")
  adminIds              String[] @map("admin_ids")
  memberIds             String[] @map("member_ids")
  baseLocationLatitude  Float?   @map("base_location_latitude")
  baseLocationLongitude Float?   @map("base_location_longitude")
  pixKey                String?  @map("pix_key")
  monthlyFee            Float    @default(0) @map("monthly_fee")
  status                String   @default("ACTIVE") @map("status")

  // Relations
  financialTransactions FinancialTransaction[]

  @@map("groups")
}

model FinancialTransaction {
  id          String            @id @default(uuid()) @map("id")
  athleteId   String            @map("athlete_id")
  matchId     String?           @map("match_id")
  groupId     String?           @map("group_id")
  amount      Float             @map("amount")
  type        TransactionType   @map("type")
  status      TransactionStatus @default(PENDING) @map("status")
  platformFee Float             @map("platform_fee")
  createdAt   DateTime          @default(now()) @map("created_at")

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  match   Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@map("financial_transactions")
}

model Match {
  id            String      @id @default(uuid()) @map("id")
  groupId       String      @map("group_id")
  date          DateTime    @map("date")
  latitude      Float       @map("latitude")
  longitude     Float       @map("longitude")
  minAge        Int         @map("min_age")
  maxAge        Int         @map("max_age")
  minOverall    Int         @map("min_overall")
  vacanciesOpen Int         @map("vacancies_open")
  status        MatchStatus @default(SCHEDULED) @map("status")

  // Relations
  financialTransactions FinancialTransaction[]

  @@map("matches")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  GROUP_INVITE
  INVITE_ACCEPTED
  INVITE_DECLINED
  SYSTEM
}

model GroupInvite {
  id        String       @id @default(uuid()) @map("id")
  groupId   String       @map("group_id")
  invitedBy String       @map("invited_by")
  athleteId String       @map("athlete_id")
  status    InviteStatus @default(PENDING) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@unique([groupId, athleteId])
  @@map("group_invites")
}

model Notification {
  id          String           @id @default(uuid()) @map("id")
  athleteId   String           @map("athlete_id")
  type        NotificationType @map("type")
  title       String           @map("title")
  body        String           @map("body")
  referenceId String?          @map("reference_id")
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}

model Ad {
  id          String  @id @default(uuid()) @map("id")
  title       String  @map("title")
  description String  @map("description")
  imageUrl    String  @map("image_url")
  targetUrl   String  @map("target_url")
  latitude    Float   @map("latitude")
  longitude   Float   @map("longitude")
  radiusInKm  Float   @map("radius_in_km")
  category    String  @map("category")
  status      String  @default("ACTIVE") @map("status")
  active      Boolean @default(true) @map("active")

  @@map("ads")
}
