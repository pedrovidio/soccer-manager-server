generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum MatchType {
  CAMPO
  SOCIETY
  FUTSAL
}

enum MatchInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MatchInviteType {
  MEMBER
  SPOT
}

enum TransactionType {
  MONTHLY
  SPOT
  GOALKEEPER_SERVICE
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELLED
}

enum FootballLevel {
  PROFESSIONAL
  AMATEUR
  CASUAL
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  GROUP_INVITE
  INVITE_ACCEPTED
  INVITE_DECLINED
  MATCH_INVITE
  MATCH_INVITE_ACCEPTED
  MATCH_INVITE_DECLINED
  SYSTEM
}

enum YearsPlaying {
  LESS_THAN_2
  TWO_TO_5
  SIX_TO_10
  MORE_THAN_10
}

enum WeeklyFrequency {
  RARELY
  ONE_TO_2
  THREE_OR_MORE
}

model Athlete {
  id                     String        @id @default(uuid()) @map("id")
  name                   String        @map("name")
  cpf                    String        @unique @map("cpf")
  email                  String        @unique @map("email")
  phone                  String        @map("phone")
  addressCep             String        @map("address_cep")
  addressStreet          String        @map("address_street")
  addressNumber          String        @map("address_number")
  addressComplement      String?       @map("address_complement")
  addressNeighborhood    String        @map("address_neighborhood")
  addressCity            String        @map("address_city")
  addressState           String        @map("address_state")
  age                    Int           @map("age")
  gender                 String        @map("gender")
  position               String        @map("position")
  footballLevel          FootballLevel @map("football_level")
  statsPace              Int           @map("stats_pace")
  statsShooting          Int           @map("stats_shooting")
  statsPassing           Int           @map("stats_passing")
  statsDribbling         Int           @map("stats_dribbling")
  statsDefense           Int           @map("stats_defense")
  statsPhysical          Int           @map("stats_physical")
  latitude               Float?        @map("latitude")
  longitude              Float?        @map("longitude")
  isGoalkeeperForHire    Boolean       @default(false) @map("is_goalkeeper_for_hire")
  isInjured              Boolean       @default(false) @map("is_injured")
  financialDebt          Float         @default(0) @map("financial_debt")
  hasCompletedAssessment Boolean       @default(false) @map("has_completed_assessment")
  pixKey                 String?       @map("pix_key")
  photoUrl               String?       @map("photo_url")

  availabilities        Availability[]
  financialTransactions FinancialTransaction[]
  assessment            Assessment?

  @@map("athletes")
}

model Assessment {
  id                   String          @id @default(uuid()) @map("id")
  athleteId            String          @unique @map("athlete_id")
  playedProfessionally Boolean         @map("played_professionally")
  highestLevel         FootballLevel   @map("highest_level")
  yearsPlaying         YearsPlaying    @map("years_playing")
  weeklyFrequency      WeeklyFrequency @map("weekly_frequency")
  selfRatedPace        Int             @map("self_rated_pace")
  selfRatedShooting    Int             @map("self_rated_shooting")
  selfRatedPassing     Int             @map("self_rated_passing")
  selfRatedDribbling   Int             @map("self_rated_dribbling")
  selfRatedDefense     Int             @map("self_rated_defense")
  selfRatedPhysical    Int             @map("self_rated_physical")
  preferredPosition    String          @map("preferred_position")
  submittedAt          DateTime        @default(now()) @map("submitted_at")

  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model Availability {
  id        String @id @default(uuid()) @map("id")
  athleteId String @map("athlete_id")
  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time")
  endTime   String @map("end_time")

  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

model Group {
  id                    String   @id @default(uuid()) @map("id")
  name                  String   @map("name")
  description           String?  @map("description")
  adminIds              String[] @map("admin_ids")
  memberIds             String[] @map("member_ids")
  baseLocationLatitude  Float?   @map("base_location_latitude")
  baseLocationLongitude Float?   @map("base_location_longitude")
  pixKey                String?  @map("pix_key")
  photoUrl              String?  @map("photo_url")
  monthlyFee            Float    @default(0) @map("monthly_fee")
  status                String   @default("ACTIVE") @map("status")

  financialTransactions FinancialTransaction[]

  @@map("groups")
}

model FinancialTransaction {
  id          String            @id @default(uuid()) @map("id")
  athleteId   String            @map("athlete_id")
  matchId     String?           @map("match_id")
  groupId     String?           @map("group_id")
  amount      Float             @map("amount")
  type        TransactionType   @map("type")
  status      TransactionStatus @default(PENDING) @map("status")
  platformFee Float             @map("platform_fee")
  createdAt   DateTime          @default(now()) @map("created_at")

  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  match   Match?  @relation(fields: [matchId], references: [id], onDelete: SetNull)
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@map("financial_transactions")
}

model Match {
  id               String      @id @default(uuid()) @map("id")
  groupId          String      @map("group_id")
  type             MatchType   @map("type")
  date             DateTime    @map("date")
  location         String      @map("location")
  latitude         Float       @map("latitude")
  longitude        Float       @map("longitude")
  totalVacancies   Int         @map("total_vacancies")
  reserveVacancies Int         @default(0) @map("reserve_vacancies")
  spotRadiusKm     Float       @default(10) @map("spot_radius_km")
  minOverall       Int         @default(0) @map("min_overall")
  minAge           Int         @default(16) @map("min_age")
  maxAge           Int         @default(99) @map("max_age")
  confirmedIds     String[]    @map("confirmed_ids")
  checkedInIds     String[]    @map("checked_in_ids")
  status           MatchStatus @default(SCHEDULED) @map("status")

  financialTransactions FinancialTransaction[]
  invites               MatchInvite[]
  ratings               PerformanceRating[]

  @@map("matches")
}

model MatchInvite {
  id         String            @id @default(uuid()) @map("id")
  matchId    String            @map("match_id")
  athleteId  String            @map("athlete_id")
  inviteType MatchInviteType   @map("invite_type")
  status     MatchInviteStatus @default(PENDING) @map("status")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, athleteId])
  @@map("match_invites")
}

model PerformanceRating {
  id           String   @id @default(uuid()) @map("id")
  matchId      String   @map("match_id")
  ratedBy      String   @map("rated_by")
  ratedAthlete String   @map("rated_athlete")
  pace         Int      @map("pace")
  shooting     Int      @map("shooting")
  passing      Int      @map("passing")
  dribbling    Int      @map("dribbling")
  defense      Int      @map("defense")
  physical     Int      @map("physical")
  createdAt    DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, ratedBy, ratedAthlete])
  @@map("performance_ratings")
}

model GroupInvite {
  id        String       @id @default(uuid()) @map("id")
  groupId   String       @map("group_id")
  invitedBy String       @map("invited_by")
  athleteId String       @map("athlete_id")
  status    InviteStatus @default(PENDING) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@unique([groupId, athleteId])
  @@map("group_invites")
}

model Notification {
  id          String           @id @default(uuid()) @map("id")
  athleteId   String           @map("athlete_id")
  type        NotificationType @map("type")
  title       String           @map("title")
  body        String           @map("body")
  referenceId String?          @map("reference_id")
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}

model GroupAdminDelegation {
  id              String    @id @default(uuid()) @map("id")
  groupId         String    @map("group_id")
  delegatedBy     String    @map("delegated_by")
  delegatedTo     String    @map("delegated_to")
  isPermanent     Boolean   @default(false) @map("is_permanent")
  matchesLimit    Int?      @map("matches_limit")
  matchesConsumed Int       @default(0) @map("matches_consumed")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("group_admin_delegations")
}

model Ad {
  id          String  @id @default(uuid()) @map("id")
  title       String  @map("title")
  description String  @map("description")
  imageUrl    String  @map("image_url")
  targetUrl   String  @map("target_url")
  latitude    Float   @map("latitude")
  longitude   Float   @map("longitude")
  radiusInKm  Float   @map("radius_in_km")
  category    String  @map("category")
  status      String  @default("ACTIVE") @map("status")
  active      Boolean @default(true) @map("active")

  @@map("ads")
}
